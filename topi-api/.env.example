PORT=8080
DB_DSN=root:password@tcp(localhost:3306)/topi?charset=utf8mb4&parseTime=True
JWT_SECRET=change-me-in-production
JWT_EXPIRE_HOURS=168
GIN_MODE=debug
# CORS_ORIGIN=* 表示允许任意来源；可指定如 http://localhost:5173
CORS_ORIGIN=*

# MCP 使用与 API 相同的 JWT 配置，无需额外变量
# MCP_BASE_URL 用于在 endpoint 事件中下发完整 message URL，避免客户端错误解析为 localhost
# 部署到远程时必填，例如: MCP_BASE_URL=http://117.50.220.90:8080
# MCP_BASE_URL=
